# =====================================================================
# admin-page — Production Environment Variables
# Set di: Vercel Dashboard → Project → Settings → Environment Variables
# =====================================================================

# Database PostgreSQL — di VPS Hostinger (IP publik VPS)
# Ganti <IP_VPS> dengan IP VPS Malaysia yang didapat dari Hostinger
# uselibpqcompat=true WAJIB ada — PostgreSQL di VPS pakai sertifikat self-signed
# (bukan dari CA publik), tanpa parameter ini driver pg modern akan menolak
# koneksi dengan error "self-signed certificate" (DEPTH_ZERO_SELF_SIGNED_CERT).
DATABASE_URL=postgresql://helpdesk_user:PASSWORD_VPS@<IP_VPS>:5432/helpdesk_db?sslmode=require&uselibpqcompat=true

# URL aplikasi ini sendiri (setelah deploy ke Vercel)
NEXT_PUBLIC_BASE_URL=https://NAMA-ADMIN.vercel.app

# URL backend FastAPI di VPS
NEXT_PUBLIC_API_URL=https://api.DOMAIN-ANDA.com

# Ollama endpoint untuk generate embedding knowledge base
# Digunakan saat tambah/edit knowledge base di halaman admin
OLLAMA_URL=https://api.DOMAIN-ANDA.com/ollama

# JWT — HARUS BERBEDA dari helpdesk-laa-frontend
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_NILAI_BARU_BERBEDA_DARI_FRONTEND

# =====================================================================
# backend_chatbot — Production Environment Variables (VPS)
# Salin sebagai .env di /opt/helpdesk-backend/.env
# =====================================================================

# Database PostgreSQL — di VPS yang sama (localhost)
DB_HOST=localhost
DB_NAME=helpdesk_db
DB_USER=helpdesk_user
DB_PASS=GANTI_PASSWORD_KUAT_MIN_20_KARAKTER
DB_PORT=5432

# CORS: isi setelah deploy ke Vercel dan URL sudah diketahui
CORS_ORIGINS=https://NAMA-FRONTEND.vercel.app,https://NAMA-ADMIN.vercel.app

# FRONTEND_URL: salah satu URL frontend (untuk backward compatibility)
FRONTEND_URL=https://NAMA-FRONTEND.vercel.app

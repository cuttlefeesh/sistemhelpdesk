# =====================================================================
# helpdesk-laa-frontend — Production Environment Variables
# Set di: Vercel Dashboard → Project → Settings → Environment Variables
# =====================================================================

# Database PostgreSQL — di VPS Hostinger (IP publik VPS)
# Ganti <IP_VPS> dengan IP VPS Malaysia yang didapat dari Hostinger
DATABASE_URL=postgresql://helpdesk_user:PASSWORD_VPS@<IP_VPS>:5432/helpdesk_db?sslmode=require

# URL aplikasi ini sendiri (setelah deploy ke Vercel, ganti dengan URL yang diberikan)
NEXT_PUBLIC_BASE_URL=https://NAMA-FRONTEND.vercel.app

# URL backend FastAPI di VPS
NEXT_PUBLIC_API_URL=https://api.DOMAIN-ANDA.com

# JWT — generate nilai baru: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_NILAI_BARU_64_KARAKTER

# Email (Gmail App Password — bukan password akun biasa)
# Setup: Google Account → Security → 2FA aktif → App Passwords → Generate
EMAIL_USER=helpdesk.laa.fte@gmail.com
EMAIL_PASS=GMAIL_APP_PASSWORD_16_KARAKTER
